<UserControl x:Class="MenuBarApp.Views.CartaMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MenuBarApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BOTONES CATEGORÍA -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="0">

            <Button Content="🍔 Comida" Width="150" Height="50" Click="Comida_Click"/>
            <Button Content="🥤 Bebida" Width="150" Height="50" Click="Bebida_Click"/>
            <Button Content="🍰 Postres" Width="150" Height="50" Click="Postre_Click"/>

        </StackPanel>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- PRODUCTOS -->
            <ListBox Grid.Column="0" ItemsSource="{Binding Productos}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="{Binding Nombre}" Width="150"/>
                            <TextBlock Text="{Binding Precio}" Width="60"/>
                            <Button Content="Añadir" 
                                    Width="30"
                                    Click="Add_Click"
                                    Tag="{Binding}"/>

                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- CARRITO -->
            <!-- CARRITO -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" ItemsSource="{Binding Carrito}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Producto.Nombre}" Width="100"/>
                                <Button Content="-" Width="25" Click="Remove_Click" Tag="{Binding}"/>
                                <TextBlock Text="{Binding Cantidad}" Width="25"/>
                                <Button Content="+" Width="25" Click="Add_Click_Carrito" Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="1" 
                           Text="{Binding Total, StringFormat='Total: {0:F2} €'}" 
                           FontSize="16" 
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           Margin="0,5,5,5"/>
                <StackPanel Grid.Row="2" Margin="5,10,5,5">

                    <TextBlock Text="¿Cómo te llamamos?"
                               Margin="0,0,0,4"/>

                    <TextBox Text="{Binding NombreCliente, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="50"
                             Margin="0,0,0,8"
                             xml:lang="es-ES">
                        <TextBox.Resources> <!-- todo este tochaco es para simular un placeholder como en html-->
                            <Style TargetType="{x:Type TextBox}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Deje aquí su nombre para avisarle"
                                               Foreground="Gray"
                                               FontStyle="Italic"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Content="Confirmar pedido"
                            Command="{Binding ConfirmarPedidoCommand}"
                            Height="40"/>

                </StackPanel>
            </Grid>

        </Grid>
    </Grid>

</UserControl>
